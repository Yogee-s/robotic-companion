# udev rules for the Robotic Companion USB devices.
#
# Installs stable `/dev/companion/<role>` symlinks that config.yaml can
# reference. Without these, device ordering depends on plug-in sequence
# and a USB re-enumeration can break motor / display bindings.
#
# Install:
#     sudo cp 99-companion.rules /etc/udev/rules.d/
#     sudo udevadm control --reload-rules && sudo udevadm trigger
#
# Then set config.yaml:
#     motor.port: /dev/companion/motor
#     display.serial_port: /dev/companion/face

# Motor bus (Feetech ST3215 via CH341 USB-serial)
# Match on serial number to distinguish from the ESP32 adapter which
# shares the same vendor/product id on many boards.
SUBSYSTEM=="tty", ATTRS{idVendor}=="1a86", ATTRS{serial}=="5B14112846", SYMLINK+="companion/motor", MODE="0666"

# ESP32 face display (CH340/CH341 UART). Match on product id only;
# the serial ID varies by device.
SUBSYSTEM=="tty", ATTRS{idVendor}=="1a86", ATTRS{idProduct}=="7523", SYMLINK+="companion/face", MODE="0666"

# ReSpeaker USB mic array (informational tag; PortAudio picks by name)
SUBSYSTEM=="usb", ATTRS{idVendor}=="2886", ATTRS{idProduct}=="0018", TAG+="companion_mic"
